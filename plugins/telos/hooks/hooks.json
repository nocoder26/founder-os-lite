{
  "description": "Telos hooks: SessionStart (one-time per project pitch + state-aware orientation) + PreToolUse (the 'AI says no' enforcement on Write/Edit).",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-build-coach.sh"
          }
        ]
      }
    ]
  }
}
